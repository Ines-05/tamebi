{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/main.py"
        },
        {
            "source": "/(assets/.*|favicon.ico|favicon.png|vite.svg)",
            "destination": "/frontend/dist/$1"
        },
        {
            "source": "/",
            "destination": "/frontend/dist/index.html"
        },
        {
            "source": "/((?!api|assets|index\\.html|favicon|vite).*)",
            "destination": "/main.py"
        }
    ]
}