{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/main.py"
        },
        {
            "source": "/(assets/.*)",
            "destination": "/frontend/dist/$1"
        },
        {
            "source": "/(.*\\.[a-z0-9]+)$",
            "destination": "/frontend/dist/$1"
        },
        {
            "source": "/",
            "destination": "/frontend/dist/index.html"
        },
        {
            "source": "/((?!api|assets|favicon|vite).*)",
            "destination": "/main.py"
        }
    ]
}