{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/main.py"
        },
        {
            "source": "/((?!api|assets|index\\.html|vite\\.svg|favicon\\.ico).*)",
            "destination": "/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/dist/$1"
        }
    ]
}