{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/index.py/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "frontend/dist/assets/$1"
        },
        {
            "source": "/((?!api|assets|favicon|vite|logo).+\\.(?:ico|png|svg|js|css|json|txt|map))$",
            "destination": "frontend/dist/$1"
        },
        {
            "source": "/",
            "destination": "frontend/dist/index.html"
        },
        {
            "source": "/((?!api|assets|favicon|vite).*)",
            "destination": "api/index.py"
        }
    ]
}