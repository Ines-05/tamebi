{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/api/index.py"
        },
        {
            "source": "/assets/(.*)",
            "destination": "frontend/dist/assets/$1"
        },
        {
            "source": "/",
            "destination": "frontend/dist/index.html"
        },
        {
            "source": "/((?!api|assets|index\\.html|vite\\.svg|favicon\\.ico).*)",
            "destination": "backend/api/index.py"
        }
    ]
}